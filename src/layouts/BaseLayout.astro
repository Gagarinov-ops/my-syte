---
import '../styles/global.css';

export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Сайты под ключ</title>
  </head>
  <body class="bg-bg-primary text-text-primary">
    <header class="border-b border-border bg-bg-secondary">
      <div class="max-w-6xl mx-auto px-4 py-4 flex justify-between items-center">
        <a href="/" class="text-xl font-bold text-accent">Сайты под ключ</a>
        <nav class="space-x-6">
          <a href="/" class="hover:text-accent transition">Главная</a>
          <a href="/services" class="hover:text-accent transition">Услуги</a>
          <a href="/portfolio" class="hover:text-accent transition">Портфолио</a>
          <a href="/contacts" class="hover:text-accent transition">Контакты</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="border-t border-border mt-16 py-8 text-center text-text-secondary text-sm bg-bg-secondary">
      <div class="max-w-6xl mx-auto px-4">
        <p>© 2025 Сайты под ключ. Все права защищены.</p>
      </div>
    </footer>
  </body>
</html>