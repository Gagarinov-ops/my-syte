---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Контакты">
  <div class="max-w-4xl mx-auto px-4 py-16">
    <h1 class="text-4xl font-bold text-center mb-4">Свяжитесь со мной</h1>
    <p class="text-gray-600 text-center mb-12">Обсудим ваш проект — отвечу быстро</p>

    <div class="grid md:grid-cols-2 gap-12">
      <!-- Контактная информация -->
      <div>
        <h2 class="text-2xl font-semibold mb-6">Мои контакты</h2>
        <div class="space-y-4">
          <div class="flex items-center gap-3">
            <span class="text-2xl">📱</span>
            <a href="tel:+7XXXXXXXXXX" class="text-blue-600 hover:underline">+7 (XXX) XXX-XX-XX</a>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-2xl">💬</span>
            <a href="https://t.me/your_username" target="_blank" class="text-blue-600 hover:underline">Telegram</a>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-2xl">📧</span>
            <a href="mailto:your@email.ru" class="text-blue-600 hover:underline">your@email.ru</a>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-2xl">💼</span>
            <a href="https://github.com/your_username" target="_blank" class="text-blue-600 hover:underline">GitHub</a>
          </div>
        </div>
      </div>

      <!-- Простая форма (без бэкенда, но с указанием куда писать) -->
      <div>
        <h2 class="text-2xl font-semibold mb-6">Напишите мне</h2>
        <form action="https://formspree.io/f/your_form_id" method="POST" class="space-y-4">
          <div>
            <label class="block text-sm font-medium mb-1">Ваше имя</label>
            <input type="text" name="name" required class="w-full border border-gray-300 rounded-lg px-4 py-2">
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">Email или Telegram</label>
            <input type="text" name="contact" required class="w-full border border-gray-300 rounded-lg px-4 py-2">
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">Сообщение</label>
            <textarea name="message" rows="4" required class="w-full border border-gray-300 rounded-lg px-4 py-2"></textarea>
          </div>
          <button type="submit" class="bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700 transition">
            Отправить
          </button>
          <p class="text-xs text-gray-500 mt-2">*Форма через Formspree (бесплатно до 50 сообщений в месяц)</p>
        </form>
      </div>
    </div>
  </div>
</BaseLayout>